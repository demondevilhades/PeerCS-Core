{
  "name": "@peercs/peercs-core",
  "version": "0.1.0",
  "description": "Client-Server Architecture over P2P using PeerJS",
  "keywords": [
    "webrtc",
    "p2p",
    "client-server",
    "peerjs",
    "peercs"
  ],
  "author": "demondevilhades",
  "license": "MIT",
  "main": "./dist/peercs.js",
  "module": "./dist/peercs.mjs",
  "types": "./dist/peercs.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "preflight": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "peerjs": "^1.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^22.9.0",
    "eslint": "^9.14.0",
    "globals": "^15.12.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  }
}